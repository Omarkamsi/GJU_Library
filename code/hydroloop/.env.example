# Postgres
POSTGRES_USER=hydroloop
POSTGRES_PASSWORD=changeme
POSTGRES_DB=hydroloop
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432

# Mosquitto
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_TLS_PORT=8883
MQTT_INGEST_USER=ingest
MQTT_INGEST_PASSWORD=changeme

# Ingest
MOCK=0                    # set to 1 to emit synthetic data instead of subscribing
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RATE_LIMIT=60/minute

# Web
NEXT_PUBLIC_API_BASE=http://localhost:8000
